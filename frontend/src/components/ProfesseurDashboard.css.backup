
.prof-layout {
  display: flex;
  height: 100vh;
  background-color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.prof-sidebar {
  width: 260px;
  background-color: #ffffff;
  border-right: 2px solid #e2e8f0;
  display: flex;
  flex-direction: column;
  padding: 20px 0;
}

.prof-profile {
  display: flex;
  align-items: center;
  padding: 0 20px 30px;
  gap: 15px;
}

.prof-avatar {
  width: 50px;
  height: 50px;
  border-radius: 12px;
  object-fit: cover;
}

.prof-info h2 {
  font-size: 16px;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 4px 0;
}

.prof-info p {
  font-size: 14px;
  color: #64748b;
  margin: 0;
}

.prof-nav {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 0 10px;
}

.prof-nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border: none;
  background: transparent;
  border-radius: 8px;
  cursor: pointer;
  color: #475569;
  font-size: 15px;
  font-weight: 500;
  transition: all 0.2s ease;
  text-align: left;
}

.prof-nav-item:hover {
  background-color: #f1f5f9;
}

.prof-nav-item.active {
  background-color: #eff6ff;
  color: #3b82f6;
}

.prof-nav-item.active .nav-icon {
  color: #3b82f6;
}

.logout-btn {
  margin-top: auto;
  color: #ef4444;
}

.logout-btn:hover {
  background-color: #fef2f2;
}

.prof-content {
  flex: 1;
  padding: 40px;
  overflow-y: auto;
}

.schedule-title {
  color: #1e293b;
  font-size: 32px;
  font-weight: 800;
  margin: 0 0 8px 0;
}

.schedule-subtitle {
  color: #64748b;
  font-size: 16px;
  margin: 0 0 40px 0;
}

.schedule-table {
  background: white;
  border-radius: 16px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  max-width: 800px;
  overflow: hidden;
}

.schedule-header {
  display: flex;
  border-bottom: 1px solid #e2e8f0;
}

.time-col {
  width: 100px;
  padding: 15px;
}

.day-col {
  flex: 1;
  padding: 15px;
  text-align: center;
  font-weight: 700;
  color: #1e293b;
  font-size: 16px;
}

.schedule-row {
  display: flex;
  border-bottom: 1px solid #f1f5f9;
  min-height: 100px;
}

.time-cell {
  width: 100px;
  padding: 20px;
  color: #64748b;
  font-weight: 600;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  border-right: 1px solid #f1f5f9;
}

.content-cell {
  flex: 1;
  padding: 15px;
}

.course-card {
  display: flex;
  background-color: #f8fafc;
  border-radius: 12px;
  overflow: hidden;
  height: 100%;
}

.course-accent {
  width: 6px;
  background-color: #3b82f6;
}

.course-details {
  padding: 15px 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.course-subject {
  margin: 0;
  font-size: 16px;
  font-weight: 700;
  color: #1e293b;
}

.course-class {
  margin: 0;
  font-size: 14px;
  color: #3b82f6;
  font-weight: 500;
}

.course-room {
  margin: 0;
  font-size: 13px;
  color: #64748b;
}

